# ============================
#  Ignore the whole models folder
# ============================
models/
models/*

# ============================
#  Python ignores
# ============================
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
env/
venv/
.f25/
*.env
*.venv

# Jupyter
.ipynb_checkpoints/

# ============================
#  Unity ignores
# ============================
# Temp / Build / Logs
[Ll]ibrary/
[Tt]emp/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Mm]emoryCaptures/

# Autogenerated VS/MonoDevelop files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb

# Crash and debug
*.stackdump

# TextMeshPro
[Tt]extMesh Pro/

# Addressables
com.unity.addressables/

# Unity Cache
/[Uu]serSettings/

# Asset Store Tools
Assets/AssetStoreTools*

# ============================
#  OS files
# ============================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# macOS
.DS_Store
.AppleDouble
.LSOverride

# ============================
#  VSCode
# ============================
.vscode/
.history/

# ============================
#  Generated composite videos (runtime output, not source)
# ============================
Assets/UI Toolkit/UI Assets/Webcam/composite_faces/*.mp4

# ============================
#  Big files you NEVER want in repo
# ============================
*.onnx
*.tflite
*.pth
*.ckpt
*.weights

# ============================
#  Unity build output (compiled artifact, not source)
# ============================
builtUIII/

# ============================
#  Runtime-generated visitor data (privacy — never commit real faces)
# ============================
PythonProject/faces/

# ============================
#  IDE project files
# ============================
PythonProject/.idea/
.idea/

